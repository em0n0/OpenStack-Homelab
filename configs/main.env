#!/usr/bin/env bash
# =============================================================================
# main.env — Configuration File  (v4.1)
# =============================================================================
#
# HOW THIS FILE WORKS
# ───────────────────
# • Every script sources this file before doing anything.
# • The Setup Wizard fills it in automatically — run:
#       sudo bash deploy.sh --wizard
# • You can also edit it manually, then validate with:
#       sudo bash deploy.sh --config
#
# SECURITY — ADD THESE TO .gitignore BEFORE COMMITTING ANYTHING
# ─────────────────────────────────────────────────────────────
#       configs/main.env
#       configs/.secrets.env
#       configs/.secrets.enc
#
# For production: move passwords to configs/.secrets.env (chmod 600).
# That file overrides the placeholder passwords below at runtime.
#
# REQUIREMENTS
# ────────────
# Debian-based distro (Ubuntu 20.04+, Debian 11+, Mint 21+)
# systemd + apt + kernel 5.4+
# Minimum 8 GB RAM, 20 GB free disk
# =============================================================================

# ─── CONFIG SCHEMA VERSION ────────────────────────────────────────────────────
# Checked by deploy.sh on startup. If this doesn't match what the scripts
# expect, you'll be prompted to re-run the wizard.
CONFIG_VERSION="4.0"

# ─── QUICK SETUP MODE ─────────────────────────────────────────────────────────
# Set to "true" to skip interactive confirmations in the wizard and accept
# all auto-detected values (IP, interface, region). You will still be prompted
# for passwords — those are never skipped.
QUICK_SETUP="false"

# ─── DISTRO & HARDWARE (auto-set by the wizard) ───────────────────────────────
# Do not edit these manually — the wizard sets them after detection.
DISTRO_FAMILY="debian"
HARDWARE_TYPE="unknown"

# ─── DEPLOYMENT MODE ──────────────────────────────────────────────────────────
# all-in-one  → everything on one machine (start here — easiest, works on a VM)
# multi-node  → separate controller / compute / storage nodes (production)
DEPLOY_MODE="all-in-one"

# ─── AUTO-DETECT PRIMARY IP ───────────────────────────────────────────────────
# Finds the IP of the interface that holds the default route.
# Falls back to the first non-loopback IP, then __CHANGE_ME__ if nothing found.
# The wizard overwrites this with your confirmed choice.
# You should never need to edit this function — the wizard handles it.
_detect_primary_ip() {
    local ip=""

    # Method 1: IP on the default-route interface
    local default_iface
    default_iface=$(ip route show default 2>/dev/null | awk '/default/ {print $5}' | head -1)
    if [[ -n "${default_iface}" ]]; then
        ip=$(ip -4 addr show "${default_iface}" 2>/dev/null \
             | awk '/inet / {print $2}' | cut -d/ -f1 | head -1)
    fi

    # Method 2: First non-loopback, non-docker IP
    if [[ -z "${ip}" ]]; then
        ip=$(ip -4 addr show 2>/dev/null \
             | awk '/inet / {print $2}' \
             | cut -d/ -f1 \
             | grep -v '^127\.\|^172\.1[6-9]\.\|^172\.2[0-9]\.\|^172\.3[01]\.\|^10\.0\.2\.' \
             | head -1)
    fi

    echo "${ip:-__CHANGE_ME__}"
}

# ─── AUTO-DETECT PRIMARY INTERFACE ────────────────────────────────────────────
# Returns the interface that holds the default route.
# Falls back to the first physical NIC, then 'eth0'.
_detect_primary_iface() {
    local iface=""

    # Method 1: default route interface
    iface=$(ip route show default 2>/dev/null | awk '/default/ {print $5}' | head -1)

    # Method 2: first non-virtual interface with a physical device link
    if [[ -z "${iface}" ]]; then
        for candidate in $(ls /sys/class/net/ 2>/dev/null | sort); do
            [[ "${candidate}" == lo ]]       && continue
            [[ "${candidate}" == docker* ]]  && continue
            [[ "${candidate}" == virbr* ]]   && continue
            [[ "${candidate}" == veth* ]]    && continue
            [[ "${candidate}" == br-* ]]     && continue
            if [[ -e "/sys/class/net/${candidate}/device" ]]; then
                iface="${candidate}"
                break
            fi
        done
    fi

    echo "${iface:-eth0}"
}

# ─── NODE IPs ─────────────────────────────────────────────────────────────────
# Auto-detected at source time. The wizard will confirm / override these.
# If HOST_IP shows as __CHANGE_ME__, run: sudo bash deploy.sh --wizard
HOST_IP="$(_detect_primary_ip)"
CONTROLLER_IP="${HOST_IP}"
STORAGE_IP="10.0.0.30"

# Space-separated list (bash arrays cannot be exported to child processes).
# To use as an array in a script:  read -ra COMPUTE_IPS <<< "${COMPUTE_IPS_STR}"
COMPUTE_IPS_STR="10.0.0.20"

# ─── NETWORK INTERFACES ───────────────────────────────────────────────────────
# Auto-detected at source time. The wizard will confirm / override these.
#
# ⚠  Bare-metal warning: Neutron takes exclusive control of INTERFACE_NAME
#    for VM traffic. If this is your SSH/management interface, you will lose
#    your connection when Neutron starts. Use a SECOND NIC for VM traffic.
INTERFACE_NAME="$(_detect_primary_iface)"
CONTROLLER_IFACE="${INTERFACE_NAME}"
COMPUTE_IFACE="${INTERFACE_NAME}"
STORAGE_IFACE="${INTERFACE_NAME}"

# ─── PASSWORDS ────────────────────────────────────────────────────────────────
# The wizard will replace these. Do not deploy with the placeholders below.
#
# Better approach: put real passwords in configs/.secrets.env (chmod 600, never commit).
# That file is loaded by every script and overrides these values at runtime.
#
# Password guide:
#   ADMIN_PASS   — Horizon dashboard login + openstack CLI (human account)
#   DB_PASS      — MariaDB root + all service databases
#   RABBIT_PASS  — RabbitMQ message queue (service-to-service communication)
#   SERVICE_PASS — Shared by Nova, Neutron, Glance service accounts in Keystone
ADMIN_PASS="REPLACE_WITH_STRONG_PASSWORD"
DB_PASS="REPLACE_WITH_STRONG_PASSWORD"
RABBIT_PASS="REPLACE_WITH_STRONG_PASSWORD"
SERVICE_PASS="REPLACE_WITH_STRONG_PASSWORD"

# ─── OPENSTACK SETTINGS ───────────────────────────────────────────────────────
# REGION_NAME: OpenStack supports multiple regions (like AWS us-east-1).
#              Leave as RegionOne unless you are building a multi-region cloud.
# CONTROLLER:  Hostname used in Keystone endpoint URLs and /etc/hosts entries.
# OS_RELEASE:  OpenStack version codename. caracal = 2024.1 release.
#              Do not change this unless upgrading to a newer release.
REGION_NAME="RegionOne"
CONTROLLER="controller"
OS_RELEASE="caracal"

# ─── KEYSTONE SERVICE CATALOG ─────────────────────────────────────────────────
# Space-separated list of services to register in the Keystone catalog.
# Each service listed here gets public, internal, and admin endpoints created.
# keystone + glance + placement are always registered regardless of this list.
# The wizard manages this — set via Step 5 of the Setup Wizard.
KEYSTONE_SERVICES_STR="keystone glance placement nova neutron"

# ─── OPTIONAL SERVICES ────────────────────────────────────────────────────────
# Set to "true" to install. Use the wizard Step 5/6, or edit directly.
# Resource usage notes are shown next to each service.
#
# Cinder     — Block storage volumes (like AWS EBS). ~200MB RAM.
# Swift      — Object/blob storage (like AWS S3). ~300MB RAM.
# Heat       — Orchestration / Infrastructure-as-Code. ~150MB RAM.
# Ceilometer — Telemetry & billing metrics. ⚠ Resource-heavy: 1-2GB RAM.
# Barbican   — Encrypted secrets manager (certs, keys). ~100MB RAM.
# Octavia    — Load balancer (requires Amphora image). ~300MB RAM.
# Manila     — Shared filesystem service (NFS/CIFS). ~200MB RAM.
# Designate  — DNS as a service. ~100MB RAM.
INSTALL_CINDER="false"
INSTALL_SWIFT="false"
INSTALL_HEAT="false"
INSTALL_CEILOMETER="false"
INSTALL_BARBICAN="false"
INSTALL_OCTAVIA="false"
INSTALL_MANILA="false"
INSTALL_DESIGNATE="false"

# ─── KUBERNETES ───────────────────────────────────────────────────────────────
# Settings for deploying a Kubernetes cluster INSIDE your OpenStack cloud.
# Requires base OpenStack to be fully deployed first.
K8S_WORKER_COUNT=2
K8S_KEYPAIR_NAME="k8s-key"
K8S_EXTERNAL_NETWORK="public"
K8S_POD_CIDR="10.244.0.0/16"

# ─── SSL / LET'S ENCRYPT ──────────────────────────────────────────────────────
# For HTTPS on OpenStack API endpoints.
# Requires: a public IP, a registered domain name, and port 80 open for ACME.
ACME_EMAIL="admin@yourdomain.com"
OPENSTACK_DOMAIN="cloud.yourdomain.com"
DEPLOY_TO_BARBICAN="false"

# ─── BACKUP ───────────────────────────────────────────────────────────────────
# BACKUP_PATH:         Where backup archives are stored.
# BACKUP_KEEP_DAYS:    Backups older than this are auto-deleted by prune_old_logs().
# SWIFT_BACKUP_*:      Upload backups to your own Swift object storage (requires Swift).
BACKUP_PATH="/var/backups/openstack"
BACKUP_KEEP_DAYS=7
SWIFT_BACKUP_ENABLED="false"
SWIFT_BACKUP_CONTAINER="openstack-backups"

# ─── LOGGING ──────────────────────────────────────────────────────────────────
# Deploy logs are kept in logs/. Logs older than LOG_KEEP_DAYS are auto-pruned.
LOG_KEEP_DAYS=30

# ─── MONITORING & ALERTS ──────────────────────────────────────────────────────
# Leave empty to disable alerts. Fill in to get notified when services go down.
#
# Slack:  Create an Incoming Webhook at https://api.slack.com/apps
#         and paste the URL here.
# Email:  Requires an SMTP server (Gmail, SendGrid, your own MTA, etc.)
SLACK_WEBHOOK_URL=""
ALERT_EMAIL=""
MONITOR_INTERVAL=30
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# ─── HARDENING ────────────────────────────────────────────────────────────────
# HARDENING_AUDIT_ONLY="true"  → check only, make no changes (safe to run any time)
# HARDENING_AUDIT_ONLY="false" → check + auto-fix (makes system changes)
HARDENING_AUDIT_ONLY="false"

# ─── EXPORTS ──────────────────────────────────────────────────────────────────
# Makes all variables above available to child processes (sub-scripts).
# Without export, a variable set here only exists in the current shell.
export CONFIG_VERSION QUICK_SETUP
export DISTRO_FAMILY HARDWARE_TYPE
export DEPLOY_MODE
export HOST_IP CONTROLLER_IP STORAGE_IP COMPUTE_IPS_STR
export INTERFACE_NAME CONTROLLER_IFACE COMPUTE_IFACE STORAGE_IFACE
export ADMIN_PASS DB_PASS RABBIT_PASS SERVICE_PASS
export REGION_NAME CONTROLLER OS_RELEASE
export KEYSTONE_SERVICES_STR
export INSTALL_CINDER INSTALL_SWIFT INSTALL_HEAT INSTALL_CEILOMETER
export INSTALL_BARBICAN INSTALL_OCTAVIA INSTALL_MANILA INSTALL_DESIGNATE
export K8S_WORKER_COUNT K8S_KEYPAIR_NAME K8S_EXTERNAL_NETWORK K8S_POD_CIDR
export ACME_EMAIL OPENSTACK_DOMAIN DEPLOY_TO_BARBICAN
export BACKUP_PATH BACKUP_KEEP_DAYS SWIFT_BACKUP_ENABLED SWIFT_BACKUP_CONTAINER
export LOG_KEEP_DAYS
export SLACK_WEBHOOK_URL ALERT_EMAIL MONITOR_INTERVAL
export SMTP_HOST SMTP_PORT SMTP_USER SMTP_PASS
export HARDENING_AUDIT_ONLY

# ─── OPENSTACK CLI AUTH ───────────────────────────────────────────────────────
# These are read automatically by the 'openstack' CLI tool.
# After sourcing this file, you can run 'openstack server list' without
# supplying credentials — the CLI finds them here.
export OS_USERNAME=admin
export OS_PASSWORD="${ADMIN_PASS}"
export OS_PROJECT_NAME=admin
export OS_USER_DOMAIN_NAME=Default
export OS_PROJECT_DOMAIN_NAME=Default
export OS_AUTH_URL="http://${HOST_IP}:5000/v3"
export OS_IDENTITY_API_VERSION=3
export OS_IMAGE_API_VERSION=2
